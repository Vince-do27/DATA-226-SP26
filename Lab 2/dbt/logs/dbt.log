create or replace temporary table "USER_DB_BOA"."SNAPSHOT"."SNAPSHOT_WEATHER_DATA__dbt_tmp"
         as
        (

    with snapshot_query as (

        


SELECT * FROM USER_DB_BOA.analytics.stg_weather_data

    ),

    snapshotted_data as (

        select *,
            city || '-' || weather_date as dbt_unique_key

        from "USER_DB_BOA"."SNAPSHOT"."SNAPSHOT_WEATHER_DATA"
        where dbt_valid_to is null

    ),

    insertions_source_data as (

        select
            *,
            city || '-' || weather_date as dbt_unique_key,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_updated_at,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_from,
            nullif(to_timestamp_ntz(convert_timezone('UTC', current_timestamp())), to_timestamp_ntz(convert_timezone('UTC', current_timestamp()))) as dbt_valid_to,
            md5(coalesce(cast(city || '-' || weather_date as varchar ), '')
         || '|' || coalesce(cast(to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as varchar ), '')
        ) as dbt_scd_id

        from snapshot_query
    ),

    updates_source_data as (

        select
            *,
            city || '-' || weather_date as dbt_unique_key,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_updated_at,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_from,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_to

        from snapshot_query
    ),

    deletes_source_data as (

        select
            *,
            city || '-' || weather_date as dbt_unique_key
        from snapshot_query
    ),
    

    insertions as (

        select
            'insert' as dbt_change_type,
            source_data.*

        from insertions_source_data as source_data
        left outer join snapshotted_data on snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
        where snapshotted_data.dbt_unique_key is null
           or (
                snapshotted_data.dbt_unique_key is not null
            and (
                (snapshotted_data."PRECIPITATION_SUM" != source_data."PRECIPITATION_SUM"
        or
        (
            ((snapshotted_data."PRECIPITATION_SUM" is null) and not (source_data."PRECIPITATION_SUM" is null))
            or
            ((not snapshotted_data."PRECIPITATION_SUM" is null) and (source_data."PRECIPITATION_SUM" is null))
        ) or snapshotted_data."WEATHER_CODE" != source_data."WEATHER_CODE"
        or
        (
            ((snapshotted_data."WEATHER_CODE" is null) and not (source_data."WEATHER_CODE" is null))
            or
            ((not snapshotted_data."WEATHER_CODE" is null) and (source_data."WEATHER_CODE" is null))
        ))
            )
        )

    ),

    updates as (

        select
            'update' as dbt_change_type,
            source_data.*,
            snapshotted_data.dbt_scd_id

        from updates_source_data as source_data
        join snapshotted_data on snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
        where (
            (snapshotted_data."PRECIPITATION_SUM" != source_data."PRECIPITATION_SUM"
        or
        (
            ((snapshotted_data."PRECIPITATION_SUM" is null) and not (source_data."PRECIPITATION_SUM" is null))
            or
            ((not snapshotted_data."PRECIPITATION_SUM" is null) and (source_data."PRECIPITATION_SUM" is null))
        ) or snapshotted_data."WEATHER_CODE" != source_data."WEATHER_CODE"
        or
        (
            ((snapshotted_data."WEATHER_CODE" is null) and not (source_data."WEATHER_CODE" is null))
            or
            ((not snapshotted_data."WEATHER_CODE" is null) and (source_data."WEATHER_CODE" is null))
        ))
        )
    ),

    deletes as (

        select
            'delete' as dbt_change_type,
            source_data.*,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_from,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_updated_at,
            to_timestamp_ntz(convert_timezone('UTC', current_timestamp())) as dbt_valid_to,
            snapshotted_data.dbt_scd_id

        from snapshotted_data
        left join deletes_source_data as source_data on snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
        where source_data.dbt_unique_key is null
    )

    select * from insertions
    union all
    select * from updates
    union all
    select * from deletes

        );
